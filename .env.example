# Copy this to .env and fill in your values

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Sheets
# Leave GOOGLE_SHEET_ID empty to create a new spreadsheet automatically
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# Bolagsverket API (OAuth2) — for future company enrichment
BOLAGSVERKET_CLIENT_ID=your_client_id_here
BOLAGSVERKET_CLIENT_SECRET=your_client_secret_here
